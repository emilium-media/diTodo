// prisma/schema.prisma

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ------------------------------------------------------
// 🔐 NEXTAUTH: Tablas de Seguridad (Auth.js)
// ------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ------------------------------------------------------
// 👤 PERFIL DE USUARIO UNIFICADO (Auth + Negocio)
// ------------------------------------------------------
model User {
  id            String    @id @default(cuid()) // Auth exige CUID
  
  // Campos exigidos por NextAuth
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  
  // 🏢 Relación con el Inquilino (Workspace)
  workspaceId   String?   // Opcional para que Auth pueda crear al usuario antes de asignarle un Workspace
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // 🔒 Credenciales y Accesos (Negocio)
  alias         String?   @unique 
  passwordHash  String?   // Opcional porque los de Google no tienen password
  
  // 📝 Datos Personales (Negocio)
  nombre        String?
  apellido      String?
  whapp         String?  
  nacionalidad  String?
  
  // 📍 Ubicación (Negocio)
  direccion     String?
  localidad     String?
  cp            String?  
  pais          String?
  
  // 📂 Multimedia y Sistema (Negocio)
  avatarUrl     String?  
  storagePath   String?   
  
  // ⚙️ Configuraciones
  settings      Json?    
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  accounts      Account[]
  sessions      Session[]
  groups        UserGroup[]
  tasksAssigned Task[]      @relation("TaskAssignee")
  files         FileAsset[]

  @@map("users")
}


// ------------------------------------------------------
// 🏢 1. ESPACIO DE TRABAJO (Workspace - Ex Account)
// ------------------------------------------------------
model Workspace {
  id        String   @id @default(uuid())
  name      String   // Ej: "Familia Pérez", "Empresa DiTodo"
  createdAt DateTime @default(now())
  
  // Relaciones
  users     User[]
  groups    Group[]
  tasks     Task[]
  files     FileAsset[]

  @@map("workspaces")
}

// ------------------------------------------------------
// 👥 3. GRUPOS Y DEPARTAMENTOS
// ------------------------------------------------------
model Group {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String    
  description String?
  
  // Relaciones
  members     UserGroup[]
  createdAt   DateTime @default(now())

  @@map("groups")
}

// ------------------------------------------------------
// 🤝 3.1 TABLA INTERMEDIA: USUARIOS <> GRUPOS
// ------------------------------------------------------
model UserGroup {
  userId      String
  groupId     String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role        String    @default("MEMBER") // ADMIN, MEMBER, VIEWER

  @@id([userId, groupId]) 
  @@map("user_groups")
}

// ------------------------------------------------------
// 📝 4. TAREAS Y ACTIVIDADES (Calendario/Cronograma)
// ------------------------------------------------------
model Task {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  title       String
  description String?   @db.Text
  status      String    @default("DRAFT") 
  
  // Tiempos y Cronogramas
  startDate   DateTime?
  endDate     DateTime?
  isAllDay    Boolean   @default(false)
  
  // Asignación
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  attachments FileAsset[]

  @@map("tasks")
}

// ------------------------------------------------------
// 📂 5. REPOSITORIO DE ARCHIVOS Y LOGS
// ------------------------------------------------------
model FileAsset {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Dueño del archivo
  uploaderId  String
  uploader    User      @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  
  // Metadatos del archivo
  fileName    String    
  mimeType    String    
  sizeBytes   Int      
  filePath    String    
  
  // Relación opcional con tareas
  taskId      String?
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  uploadedAt  DateTime @default(now())

  @@map("file_assets")
}